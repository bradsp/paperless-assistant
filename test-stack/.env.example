# Copy to `.env` and tweak as needed. `docker compose` auto-loads `.env`.

# Vision model Ollama will pull + use. moondream (~1.7GB) is small and CPU-friendly
# and matches the assistant's vision-model hints. llava:7b (~4.7GB) transcribes
# better but is heavier. If you change this, also update `model:` in config.yml.
OLLAMA_MODEL=moondream

# Paperless superuser (auto-created on first boot; used only to mint an API token).
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=admin

# Paperless-NGX image tag. The assistant supports BOTH the v2 line and the v3
# beta and auto-detects which one it's talking to (no version setting needed), so
# you can swap this to smoke-test either generation. Default is the current
# STABLE (v2). To try v3, use the rolling beta tag or a pinned beta:
#   PA_PAPERLESS_IMAGE=ghcr.io/paperless-ngx/paperless-ngx:beta
#   PA_PAPERLESS_IMAGE=ghcr.io/paperless-ngx/paperless-ngx:v3.0.0-beta.rc2
# NOTE: v3 makes PAPERLESS_SECRET_KEY mandatory — this stack already sets one
# (throwaway-not-a-secret) so v3 boots; on a real v3 upgrade, rotating the secret
# invalidates existing API tokens and they must be reissued.
PA_PAPERLESS_IMAGE=ghcr.io/paperless-ngx/paperless-ngx:latest

# Published host ports.
PAPERLESS_PORT=8000
OLLAMA_PORT=11434

# Timezone for Paperless.
TZ=UTC
